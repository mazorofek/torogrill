FROM --platform=linux/amd64 node:24-slim AS builder

WORKDIR /app

RUN npm install -g pnpm@11.1.3

COPY . .

ENV npm_config_user_agent=pnpm/11.1.3
ENV PORT=5173
ENV BASE_PATH=/
ENV API_ORIGIN=http://api:5001

RUN pnpm install --frozen-lockfile --ignore-scripts
RUN pnpm --filter @workspace/toro-grill run build

FROM --platform=linux/amd64 nginx:1.27-alpine AS runner

COPY docker/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/artifacts/toro-grill/dist/public /usr/share/nginx/html

EXPOSE 80
